{
  "nodes": [
    {
      "id": "safe_llm",
      "name": "safe_agent",
      "type": "llm",
      "config": {
        "model": "gpt-4o-mini",
        "prompt": "Authenticate using ${OPENAI_API_KEY} from the environment",
        "api_key": "${API_KEY}"
      }
    },
    {
      "id": "safe_tool",
      "name": "safe_tool",
      "type": "tool",
      "config": {
        "category": "api",
        "headers": {
          "Authorization": "Bearer {{api_token}}",
          "X-Api-Key": "{{service_key}}"
        }
      }
    },
    {
      "id": "safe_output",
      "name": "output",
      "type": "output",
      "config": {}
    }
  ],
  "edges": [
    { "from": "safe_llm",  "to": "safe_tool" },
    { "from": "safe_tool", "to": "safe_output" }
  ],
  "entry_node_id": "safe_llm"
}
